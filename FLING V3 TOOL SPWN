-- [[ PROJETO KILL V4 - MULTI-SELECTION (FORCE INJECTED - OMNI ORBIT) ]] --
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

local lp = Players.LocalPlayer
local character = lp.Character or lp.CharacterAdded:Wait()
local camera = Workspace.CurrentCamera
local mouse = lp:GetMouse()

-- --- VARIÁVEIS DE ESTADO ---
local objetosSelecionados = {} -- Tabela para armazenar múltiplos objetos
local conexaoAtaque = nil

-- --- TRANCAR AUTORIDADE DE REDE (SIMULATION RADIUS MÁXIMO) ---
local sethp = sethiddenproperty or set_hidden_property
if sethp then
    task.spawn(function()
        RunService.RenderStepped:Connect(function()
            pcall(function()
                sethp(lp, "SimulationRadius", 1e30)
                sethp(lp, "MaxSimulationRadius", 1e30)
            end)
        end)
    end)
end

-- --- CRIAÇÃO DA TOOL ---
local tool = Instance.new("Tool")
tool.Name = "SELECT MATTER V4"
tool.RequiresHandle = false
tool.Parent = lp:WaitForChild("Backpack")

-- --- INJEÇÃO DOS MOTORES DE FORÇA BRUTA (MÉTODO FLING BALL) ---
local function aplicarMotoresFling(corpo)
    for _, child in pairs(corpo:GetChildren()) do
        if child:IsA("BodyVelocity") or child:IsA("BodyAngularVelocity") or child.Name == "BobsledSpinMotor" then
            child:Destroy()
        end
    end

    corpo.CanCollide = true
    corpo.Massless = false

    corpo.CustomPhysicalProperties = PhysicalProperties.new(100, 100, 0, 100, 100)
    local forcaMassiva = Vector3.new(math.huge * math.huge, math.huge * math.huge, math.huge * math.huge)

    -- 1. MOTOR LINEAR
    local velocity = Instance.new("BodyVelocity")
    velocity.Name = "FlingPowerLinear"
    velocity.Velocity = Vector3.new(999999, 999999, 999999)
    velocity.MaxForce = forcaMassiva
    velocity.P = math.huge
    velocity.Parent = corpo  

    -- 2. MOTOR ANGULAR
    local angularVelocity = Instance.new("BodyAngularVelocity")
    angularVelocity.Name = "FlingPowerAngular"
    angularVelocity.AngularVelocity = Vector3.new(999999, 999999, 999999)
    angularVelocity.MaxTorque = forcaMassiva
    angularVelocity.P = math.huge
    angularVelocity.Parent = corpo
end

-- --- MÓDULO 5: SEAT-HOPPING DINÂMICO (PEGA A POSIÇÃO ATUAL DO ASSENTO) ---
local function executarBypassNetworkOwnership(assentoAlvo)
    local meuHRP = character:FindFirstChild("HumanoidRootPart")
    local meuHum = character:FindFirstChildOfClass("Humanoid")
    if not meuHRP or not meuHum or not assentoAlvo then return end

    -- Salva o ponto seguro onde você estava antes do clique
    local posicaoOriginal = meuHRP.CFrame

    print("⚡ [CUBNIT] Passo 1: Teletransportando para a posição ATUAL do assento...")
    meuHRP.CFrame = assentoAlvo.CFrame
    
    -- PASSO 1: Tempo necessário para o motor sincronizar e herdar o controle físico
    task.wait(0.5) 

    print("⚡ [CUBNIT] Passo 2: Forçando saída mecânica do veículo...")
    meuHum.Sit = false
    meuHum.Jump = true -- Destrói a solda interna nativa do Roblox
    
    -- Move o personagem para cima para sair completamente da hitbox do helicóptero
    meuHRP.CFrame = assentoAlvo.CFrame + Vector3.new(0, 8, 0) 
    
    -- PASSO 2: Tempo de espera para o servidor confirmar que você se desvinculou do assento
    task.wait(0.3) 

    print("✅ [CUBNIT] Passo 3: Retornando em segurança para a posição de origem.")
    meuHRP.CFrame = posicaoOriginal
end

-- --- EXECUÇÃO DO ATAQUE EM MASSA ---
local function iniciarAtaqueMassa(alvoPlayer)
    local alvoChar = alvoPlayer.Character
    if not alvoChar or not alvoChar:FindFirstChild("HumanoidRootPart") then return end

    local alvoHRP = alvoChar.HumanoidRootPart
    local alvoHum = alvoChar.Humanoid
    local meuHRP = character:FindFirstChild("HumanoidRootPart")

    if not meuHRP or #objetosSelecionados == 0 then return end

    print("⚔️ INJETANDO MULTI-FLING EM: " .. alvoPlayer.Name .. " COM " .. #objetosSelecionados .. " OBJETOS.")

    for _, objeto in pairs(objetosSelecionados) do
        if objeto and objeto.Parent then
            aplicarMotoresFling(objeto)

            local nc = Instance.new("NoCollisionConstraint", objeto)
            nc.Part0 = objeto
            nc.Part1 = meuHRP

            if sethp then
                pcall(function() sethp(objeto, "NetworkOwner", lp) end)
            elseif objeto.SetNetworkOwner then
                pcall(function() objeto:SetNetworkOwner(lp) end)
            end
        end
    end

    local partesAlvo = {"HumanoidRootPart", "Head", "LowerTorso"}
    local indexParte = 1

    conexaoAtaque = RunService.Heartbeat:Connect(function()
        if not alvoChar.Parent or alvoHum.Health <= 0 or #objetosSelecionados == 0 then
            if conexaoAtaque then conexaoAtaque:Disconnect() end
            print("💥 Alvo neutralizado ou lista vazia. Resetando.")
            objetosSelecionados = {}
            tool.Name = "SELECT MATTER V3"
            return
        end

        local nomeParte = partesAlvo[indexParte]
        local p = alvoChar:FindFirstChild(nomeParte)

        if p then
            local offsetCurto = Vector3.new(0, 0, 0)
            if p.Velocity.Magnitude > 0.1 then
                offsetCurto = p.Velocity.Unit * 0.8
            end

            local tempo = tick() * 45 

            for i = #objetosSelecionados, 1, -1 do
                local objeto = objetosSelecionados[i]

                if objeto and objeto.Parent then
                    local angulo = tempo + (i * (math.pi / #objetosSelecionados))
                    local raio = 1 + (math.sin(tempo + i) * 0.5 + 0.5) 

                    local offsetOrbital = Vector3.new(
                        math.cos(angulo) * raio,
                        math.sin(angulo * 1.5) * raio, 
                        math.sin(angulo) * raio
                    )

                    local posicaoFinal = p.Position + offsetCurto + offsetOrbital
                    local direcaoGiro = CFrame.Angles(math.sin(tempo) * 3, math.cos(tempo) * 3, math.sin(tempo * 2) * 3)

                    objeto.CFrame = CFrame.new(posicaoFinal) * direcaoGiro

                    objeto.Velocity = Vector3.new(999999, 999999, 999999)
                    objeto.RotVelocity = Vector3.new(999999, 999999, 999999)
                else
                    table.remove(objetosSelecionados, i)
                end
            end
        end

        indexParte = indexParte + 1
        if indexParte > #partesAlvo then indexParte = 1 end
    end)
end

-- --- GATILHO DE RECONHECIMENTO E SELEÇÃO ---
tool.Activated:Connect(function()
    local unitRay = camera:ScreenPointToRay(mouse.X, mouse.Y)
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {character}

    local raycastResult = Workspace:Raycast(unitRay.Origin, unitRay.Direction * 50000, raycastParams)

    if raycastResult and raycastResult.Instance then
        local hitPart = raycastResult.Instance
        local model = hitPart:FindFirstAncestorOfClass("Model")

        -- CONDICIONAL: É um jogador?
        if model and model:FindFirstChild("Humanoid") then
            local tPlayer = Players:GetPlayerFromCharacter(model)

            if tPlayer and tPlayer ~= lp then
                if #objetosSelecionados > 0 then
                    if conexaoAtaque then conexaoAtaque:Disconnect() end
                    iniciarAtaqueMassa(tPlayer)
                else
                    warn("❌ Nenhuma matéria selecionada ainda! Clique em objetos físicos primeiro.")
                end
            end
        else
            -- CONDICIONAL: É um objeto/veículo
            local alvoFisico = nil
            local modeloVeiculo = hitPart:FindFirstAncestorOfClass("Model") or hitPart

            if hitPart.Anchored == false then
                if hitPart:IsA("BasePart") then
                    alvoFisico = hitPart
                elseif modeloVeiculo:IsA("Model") and modeloVeiculo.PrimaryPart then
                    alvoFisico = modeloVeiculo.PrimaryPart
                else
                    alvoFisico = hitPart
                end
            end

            if alvoFisico then
                if not table.find(objetosSelecionados, alvoFisico) then
                    table.insert(objetosSelecionados, alvoFisico)
                    print("➕ MATÉRIA ADICIONADA: " .. alvoFisico.Name .. " (Total: " .. #objetosSelecionados .. ")")
                    tool.Name = "DESTROY " .. #objetosSelecionados

                    -- [CORREÇÃO DE INSTÂNCIA EXCLUSIVA]: Procura o assento apenas dentro do modelo isolado que você clicou
                    local assentoEncontrado = nil
                    if modeloVeiculo then
                        assentoEncontrado = modeloVeiculo:FindFirstChildOfClass("VehicleSeat") or modeloVeiculo:FindFirstChild("PilotSeat", true)
                    end
                    
                    -- Se o objeto não for um modelo direto mas fizer parte da hierarquia de Helicópteros, isola o pai correto
                    if not assentoEncontrado and hitPart:FindFirstAncestor("Helicopters") then
                        local modeloPaiDireto = hitPart:FindFirstAncestor("ChinookRescue") or hitPart.Parent
                        if modeloPaiDireto then
                            assentoEncontrado = modeloPaiDireto:FindFirstChild("PilotSeat", true) or modeloPaiDireto:FindFirstChildOfClass("VehicleSeat")
                        end
                    end

                    -- Se encontrou o assento pertencente unicamente àquela cópia, executa o bypass
                    if assentoEncontrado and assentoEncontrado:IsA("BasePart") then
                        executarBypassNetworkOwnership(assentoEncontrado)
                    else
                        warn("⚠ Objeto selecionado, mas o assento específico desta instância não foi localizado.")
                    end
                end
            else
                print("♻️ Seleção limpa.")
                objetosSelecionados = {}
                tool.Name = "SELECT MATTER V3"
                if conexaoAtaque then conexaoAtaque:Disconnect() end
            end
        end
    end
end)

tool.Unequipped:Connect(function()
    if conexaoAtaque then conexaoAtaque:Disconnect() end
    objetosSelecionados = {}
    tool.Name = "SELECT MATTER V3"
end)